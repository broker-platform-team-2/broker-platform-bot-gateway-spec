# Copy this file to `.env` and fill in real values. `.env` is gitignored.

# Broker platform user-gateway (HTTP + WebSocket on the same port)
GATEWAY_HTTP_URL=http://localhost:8180
GATEWAY_WS_URL=ws://localhost:8180/notifications/ws

# Bot account credentials — bot registers on first run if missing
BOT_EMAIL=bot-team2@example.com
BOT_PASSWORD=change-me-please

# Seed capital to deposit on first run (simulation currency)
SEED_DEPOSIT=100000
SEED_CURRENCY=USD

# Logging
LOG_LEVEL=INFO

# Set to 1 to record all WebSocket messages + orders to runs/<timestamp>.jsonl
# Required for the Streamlit dashboard (dashboards/app.py) to show live data.
REPLAY_RECORD=0
